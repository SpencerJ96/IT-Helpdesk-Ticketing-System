@model List<HelpDeskMvc.Models.TicketViewModel>

	<table class="table table-bordered table-striped">
		<thead>

			<tr>
				<th>Id</th>
				<th>Title</th>
				<th>Status</th>
				<th>Priority</th>
				<th>CreatedAt</th>
				<th>Comments</th>
				<th>Actions</th>
			</tr>
			
		</thead>
		<tbody>
			@foreach (var ticket in Model)
			{
				<tr>
					<td>@ticket.Id</td>
					<td>@ticket.Title</td>
					<td>@ticket.Status</td>
					<td>@ticket.Priority</td>
					<td>@ticket.CreatedAt</td>
					<td>@ticket.CommentCount</td>
					<td>
						<a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-primary">View</a>
					</td>
				</tr>
			}
		</tbody>
	</table>